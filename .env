APP_NAME=MemeHub
APP_ENV=production
APP_KEY=base64:NEaPne4VJ0XnReyE8QnyZXzjjnXRDQBp05P0Td1/uEU=
APP_DEBUG=false
APP_URL=https://memehub.railway.app

LOG_CHANNEL=stderr
LOG_LEVEL=info

# Gunakan variabel yang disediakan oleh Railway
DB_CONNECTION=mysql
DB_HOST=${MYSQLHOST}
DB_PORT=${MYSQLPORT}
DB_DATABASE=${MYSQLDATABASE}
DB_USERNAME=${MYSQLUSER}
DB_PASSWORD=${MYSQLPASSWORD}

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
FILESYSTEM_DISK=public
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# Gunakan Redis jika tersedia, jika tidak, ganti ke 'file'
REDIS_HOST=${REDISHOST}
REDIS_PASSWORD=${REDISPASSWORD}
REDIS_PORT=${REDISPORT}

# Konfigurasi Mail (opsional, gunakan layanan seperti Mailgun/Postmark)
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@memehub.com"
MAIL_FROM_NAME="${APP_NAME}"
